{
  "name": "audusd-daily-backtest",
  "version": "1.0.0",
  "description": "Simple daily AUD/USD FX strategy backtest (trend + trends + sentiment)",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "verify": "npm run build && npm test",
    "doctor": "tsx scripts/doctor.ts",
    "go": "tsx scripts/go.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "fetch:price": "tsx scripts/fetchPrice.ts",
    "join:daily": "tsx scripts/joinDaily.ts",
    "sweep:keywords": "tsx scripts/keywordSweep.ts",
    "sweep:params": "tsx scripts/paramSweep.ts",
    "daily:check": "tsx scripts/dailyCheck.ts",
    "compare:variants": "tsx scripts/compareVariants.ts",
    "trial": "tsx scripts/trial.ts",
    "py:strategy": "python aud_strategy/run.py",
    "open:chart": "start output/variant_equity_chart.html",
    "open:dashboard": "start output/trial_dashboard.html"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.5.2"
  }
}
