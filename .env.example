# Copy to .env and load in your shell if your tooling supports it, or set in Task Scheduler.
# Never commit real keys.

# Optional: auto-fetch Gemini reply during `npm run trial` (see docs/OPERATOR_GUIDE.md)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Optional: label for merged CSV when not using pair_id column (e.g. EURUSD)
# FX_PAIR_ID=AUDUSD
